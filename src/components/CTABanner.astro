---
interface Props {
  bgImage?: string;
  heading?: string;
  buttonText?: string;
}
const {
  bgImage = '/images/CTA-bg-1.jpg',
  heading = 'We strive to provide the Best Service in the Industry',
  buttonText = 'Contact Us Today',
} = Astro.props;
---

<section style={`
  position: relative;
  padding: 80px 0;
  background: linear-gradient(rgba(10,15,26,0.75), rgba(10,15,26,0.75)),
              url('${bgImage}') center/cover no-repeat;
  text-align: center;
`}>
  <div class="container">
    <h2 style="color:#f0f4f8;font-size:clamp(1.5rem,3vw,2.5rem);font-weight:800;margin-bottom:2rem;max-width:700px;margin-left:auto;margin-right:auto;">
      {heading}
    </h2>
    <a href="/contact-us/" style="
      display: inline-block;
      background: var(--color-accent);
      color: #0a0f1a;
      padding: 0.875rem 2rem;
      border-radius: 3px;
      font-weight: 700;
      font-size: 0.875rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: background 200ms;
    " onmouseover="this.style.background='#0090aa'" onmouseout="this.style.background='#00b4d8'">{buttonText}</a>
  </div>
</section>
