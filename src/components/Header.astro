---
const navLinks = [
  { label: 'Home',     href: '/' },
  { label: 'About',    href: '/about/' },
  { label: 'Services', href: '/services/' },
  { label: 'Projects', href: '/projects/' },
];
---

<header id="site-header" style="
  position: fixed; top: 0; left: 0; right: 0; z-index: 50;
  background: transparent;
  transition: background 300ms ease, box-shadow 300ms ease;
">
  <div class="container" style="display:flex;align-items:center;justify-content:space-between;height:64px;">
    <a href="/" style="display:flex;align-items:center;">
      <img
        src="/images/cropped-ConstrAI_Logo_White_Transparent-1-108x108.png"
        alt="ConstrAI"
        style="height:40px;width:auto;"
      />
    </a>

    <nav class="desktop-nav" style="display:flex;align-items:center;gap:2rem;">
      {navLinks.map(link => (
        <a href={link.href} style="
          color: rgba(240,244,248,0.85);
          font-size: 0.875rem;
          font-weight: 500;
          letter-spacing: 0.05em;
          text-transform: uppercase;
          transition: color 200ms;
        " onmouseover="this.style.color='#00b4d8'" onmouseout="this.style.color='rgba(240,244,248,0.85)'">{link.label}</a>
      ))}
      <a href="/contact-us/" style="
        border: 1px solid #00b4d8;
        color: #00b4d8;
        padding: 0.4rem 1rem;
        border-radius: 3px;
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        transition: background 200ms, color 200ms;
      " onmouseover="this.style.background='#00b4d8';this.style.color='#0a0f1a'" onmouseout="this.style.background='transparent';this.style.color='#00b4d8'">Contact Us</a>
    </nav>

    <button id="hamburger" aria-expanded="false" aria-controls="mobile-menu" style="
      display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:8px;
    ">
      <span style="display:block;width:24px;height:2px;background:#f0f4f8;transition:transform 300ms,opacity 300ms;"></span>
      <span style="display:block;width:24px;height:2px;background:#f0f4f8;transition:transform 300ms,opacity 300ms;"></span>
      <span style="display:block;width:24px;height:2px;background:#f0f4f8;transition:transform 300ms,opacity 300ms;"></span>
    </button>
  </div>
</header>

<div id="mobile-backdrop" style="
  position:fixed;inset:0;z-index:55;background:rgba(10,15,26,0.7);
  opacity:0;pointer-events:none;transition:opacity 250ms;
"></div>

<nav id="mobile-menu" aria-hidden="true" style="
  position:fixed;top:0;right:0;bottom:0;z-index:60;
  width:280px;background:var(--color-surface);
  transform:translateX(100%);transition:transform 250ms ease;
  display:flex;flex-direction:column;padding:1.5rem;
">
  <button id="mobile-close" style="
    align-self:flex-end;background:none;border:none;color:#f0f4f8;
    font-size:1.5rem;cursor:pointer;margin-bottom:2rem;
  ">✕</button>
  {navLinks.map(link => (
    <a href={link.href} style="
      color:#f0f4f8;font-size:1.125rem;font-weight:500;
      padding:0.75rem 0;border-bottom:1px solid var(--color-border);
    ">{link.label}</a>
  ))}
  <a href="/contact-us/" style="
    margin-top:1.5rem;background:#00b4d8;color:#0a0f1a;
    text-align:center;padding:0.75rem;border-radius:3px;
    font-weight:700;letter-spacing:0.05em;text-transform:uppercase;
  ">Contact Us</a>
</nav>

<style>
  @media (max-width: 767px) {
    .desktop-nav { display: none !important; }
    #hamburger { display: flex !important; }
  }
  #site-header.scrolled {
    background: var(--color-surface) !important;
    box-shadow: 0 2px 20px rgba(0,0,0,0.4);
  }
</style>

<script>
  const header = document.getElementById('site-header') as HTMLElement;
  const hamburger = document.getElementById('hamburger') as HTMLElement;
  const mobileMenu = document.getElementById('mobile-menu') as HTMLElement;
  const backdrop = document.getElementById('mobile-backdrop') as HTMLElement;
  const closeBtn = document.getElementById('mobile-close') as HTMLElement;

  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 50);
  }, { passive: true });

  function openMenu() {
    mobileMenu.style.transform = 'translateX(0)';
    mobileMenu.setAttribute('aria-hidden', 'false');
    backdrop.style.opacity = '1';
    backdrop.style.pointerEvents = 'auto';
    hamburger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu.style.transform = 'translateX(100%)';
    mobileMenu.setAttribute('aria-hidden', 'true');
    backdrop.style.opacity = '0';
    backdrop.style.pointerEvents = 'none';
    hamburger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  hamburger?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);
  mobileMenu?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeMenu(); });
</script>
