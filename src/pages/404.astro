---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Page Not Found">
  <Header />
  <div style="padding-top:64px;min-height:80vh;display:flex;align-items:center;justify-content:center;text-align:center;background:var(--color-bg);">
    <div>
      <div style="color:var(--color-accent);font-size:6rem;font-weight:800;line-height:1;margin-bottom:1rem;">404</div>
      <h1 style="color:#f0f4f8;font-size:2rem;font-weight:700;margin-bottom:0.75rem;">Page Not Found</h1>
      <p style="color:var(--color-muted);margin-bottom:2rem;max-width:400px;">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" style="background:#00b4d8;color:#0a0f1a;padding:0.75rem 1.75rem;border-radius:3px;font-weight:700;font-size:0.875rem;letter-spacing:0.08em;text-transform:uppercase;transition:background 200ms;" onmouseover="this.style.background='#0090aa'" onmouseout="this.style.background='#00b4d8'">Go Home</a>
    </div>
  </div>
  <Footer />
</Layout>
