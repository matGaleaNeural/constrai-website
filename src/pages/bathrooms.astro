---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceHero from '../components/ServiceHero.astro';
import ServiceGallery from '../components/ServiceGallery.astro';
import CTABanner from '../components/CTABanner.astro';
const images = [
  '/images/IMG-20250918-WA0038-2-768x1024.jpg',
  '/images/IMG_20240103_110530-1024x683.jpg',
];
---
<Layout title="Bathrooms">
  <Header />
  <div style="padding-top:64px;">
    <ServiceHero title="Bathrooms" description="Specialized tiling for luxury wet areas, en-suites, and bathrooms — combining waterproofing expertise with aesthetic precision." heroImage="/images/IMG-20250918-WA0038-2-768x1024.jpg" />
    <ServiceGallery images={images} />
    <CTABanner heading="READY? Let's Build A Plan Together" />
  </div>
  <Footer />
</Layout>
