---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout title="Contact Us">
  <Header />
  <div style="padding-top:64px;">
    <PageHero title="Contact Us" />

    <section class="section" style="background:var(--color-bg);">
      <div class="container">
        <h3 style="color:var(--color-accent);font-size:0.75rem;letter-spacing:0.15em;text-transform:uppercase;margin-bottom:0.5rem;">Get in Touch</h3>
        <p style="color:var(--color-muted);max-width:600px;line-height:1.7;margin-bottom:3rem;">
          Have a project in mind or want to learn more about our services? We'd love to hear from you. Fill in the form and we'll get back to you as soon as possible.
        </p>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;">
          <form style="display:flex;flex-direction:column;gap:1.25rem;">
            {[
              { label: 'Your Name', type: 'text', name: 'name', placeholder: 'John Smith' },
              { label: 'Email Address', type: 'email', name: 'email', placeholder: 'john@example.com' },
              { label: 'Subject', type: 'text', name: 'subject', placeholder: 'Project inquiry' },
            ].map(field => (
              <div>
                <label style="display:block;color:var(--color-text);font-size:0.875rem;font-weight:500;margin-bottom:0.375rem;">{field.label}</label>
                <input
                  type={field.type}
                  name={field.name}
                  placeholder={field.placeholder}
                  style="width:100%;background:var(--color-surface);border:1px solid var(--color-border);color:var(--color-text);padding:0.625rem 0.875rem;border-radius:4px;font-size:0.875rem;outline:none;transition:border-color 200ms;"
                  onfocus="this.style.borderColor='#00b4d8'" onblur="this.style.borderColor='rgba(0,180,216,0.18)'"
                />
              </div>
            ))}
            <div>
              <label style="display:block;color:var(--color-text);font-size:0.875rem;font-weight:500;margin-bottom:0.375rem;">Message</label>
              <textarea
                name="message"
                rows="5"
                placeholder="Tell us about your project..."
                style="width:100%;background:var(--color-surface);border:1px solid var(--color-border);color:var(--color-text);padding:0.625rem 0.875rem;border-radius:4px;font-size:0.875rem;outline:none;resize:vertical;transition:border-color 200ms;font-family:inherit;"
                onfocus="this.style.borderColor='#00b4d8'" onblur="this.style.borderColor='rgba(0,180,216,0.18)'"
              ></textarea>
            </div>
            <button type="submit" style="background:#00b4d8;color:#0a0f1a;padding:0.75rem 1.5rem;border:none;border-radius:3px;font-weight:700;font-size:0.875rem;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;transition:background 200ms;align-self:flex-start;" onmouseover="this.style.background='#0090aa'" onmouseout="this.style.background='#00b4d8'">Send Message</button>
          </form>

          <div style="display:flex;flex-direction:column;gap:1.25rem;">
            {[
              { icon: '📞', label: 'Call Us', value: '+356 99 638 741', href: 'tel:+35699638741' },
              { icon: '✉', label: 'Email', value: 'admin@constrai.com.mt', href: 'mailto:admin@constrai.com.mt' },
              { icon: '📍', label: 'Location', value: '114, Triq Il-Kanonku Bonnici, Santa Venera SVR 1072', href: null },
              { icon: '🕐', label: 'Hours', value: 'Mon–Fri 7AM–4PM / Sat–Sun 7AM–3PM', href: null },
            ].map(card => (
              <div style="display:flex;gap:1rem;background:var(--color-surface);border:1px solid var(--color-border);border-radius:8px;padding:1.25rem;">
                <span style="font-size:1.5rem;">{card.icon}</span>
                <div>
                  <p style="color:var(--color-accent);font-size:0.7rem;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:0.25rem;">{card.label}</p>
                  {card.href
                    ? <a href={card.href} style="color:var(--color-text);font-size:0.9rem;" onmouseover="this.style.color='#00b4d8'" onmouseout="this.style.color='#f0f4f8'">{card.value}</a>
                    : <p style="color:var(--color-text);font-size:0.9rem;">{card.value}</p>
                  }
                </div>
              </div>
            ))}

            <div style="border-radius:8px;overflow:hidden;border:1px solid var(--color-border);">
              <iframe
                src="https://www.google.com/maps?cid=13526401008356917401&output=embed"
                width="100%"
                height="250"
                style="border:0;display:block;"
                allowfullscreen
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="ConstrAI location"
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
  <Footer />
</Layout>

<style>
  @media (max-width: 900px) {
    .container > div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns: 1fr !important; }
  }
</style>
