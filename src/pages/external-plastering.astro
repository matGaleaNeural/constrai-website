---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceHero from '../components/ServiceHero.astro';
import ServiceGallery from '../components/ServiceGallery.astro';
import CTABanner from '../components/CTABanner.astro';
const images = [
  '/images/IMG_20240722_180001.jpg',
  '/images/IMG_20240722_190220-scaled.jpg',
];
---
<Layout title="External Plastering">
  <Header />
  <div style="padding-top:64px;">
    <ServiceHero title="External Plastering" description="Durable, aesthetically refined exterior finishes engineered to withstand Malta's climate while maintaining a premium appearance." heroImage="/images/IMG_20240722_180001.jpg" />
    <ServiceGallery images={images} />
    <CTABanner heading="READY? Let's Build A Plan Together" />
  </div>
  <Footer />
</Layout>
