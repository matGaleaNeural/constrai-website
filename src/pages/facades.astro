---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceHero from '../components/ServiceHero.astro';
import ServiceGallery from '../components/ServiceGallery.astro';
import CTABanner from '../components/CTABanner.astro';
const images = [
  '/images/IMG-20251108-WA0124.jpg',
  '/images/IMG_20240722_190220-scaled.jpg',
];
---
<Layout title="Facades">
  <Header />
  <div style="padding-top:64px;">
    <ServiceHero title="Facades" description="High-end exterior cladding and envelope solutions that deliver a striking first impression while providing long-term weather protection." heroImage="/images/IMG-20251108-WA0124.jpg" />
    <ServiceGallery images={images} />
    <CTABanner heading="READY? Let's Build A Plan Together" />
  </div>
  <Footer />
</Layout>
