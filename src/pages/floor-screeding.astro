---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceHero from '../components/ServiceHero.astro';
import ServiceGallery from '../components/ServiceGallery.astro';
import CTABanner from '../components/CTABanner.astro';
const images = [
  '/images/IMG-20251017-WA0076-1024x768.jpg',
  '/images/tiler-working-renovation-apartment-scaled.jpg',
];
---
<Layout title="Floor Screeding">
  <Header />
  <div style="padding-top:64px;">
    <ServiceHero title="Floor Screeding" description="Professional application of cementitious and self-leveling screeds to create perfectly flat, structurally sound substrates ready for any floor finish." heroImage="/images/IMG-20251017-WA0076-1024x768.jpg" />
    <ServiceGallery images={images} />
    <CTABanner heading="READY? Let's Build A Plan Together" />
  </div>
  <Footer />
</Layout>
