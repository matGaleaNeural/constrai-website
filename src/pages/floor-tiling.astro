---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceHero from '../components/ServiceHero.astro';
import ServiceGallery from '../components/ServiceGallery.astro';
import CTABanner from '../components/CTABanner.astro';
const images = [
  '/images/MicrosoftTeams-image-81-1140x445-1-1024x400.jpg',
  '/images/IMG_20240722_190220-scaled.jpg',
  '/images/tiler-working-renovation-apartment-scaled.jpg',
];
---
<Layout title="Floor Tiling">
  <Header />
  <div style="padding-top:64px;">
    <ServiceHero title="Floor Tiling" description="Precision installation of high-end ceramic, porcelain, and natural stone floor tiles for residential and commercial spaces." heroImage="/images/MicrosoftTeams-image-81-1140x445-1-1024x400.jpg" />
    <ServiceGallery images={images} />
    <CTABanner heading="READY? Let's Build A Plan Together" />
  </div>
  <Footer />
</Layout>
