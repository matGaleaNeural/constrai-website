---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceHero from '../components/ServiceHero.astro';
import ServiceGallery from '../components/ServiceGallery.astro';
import CTABanner from '../components/CTABanner.astro';
const images = [
  '/images/IMG_20240722_172415-1.jpg',
  '/images/IMG_20240722_190220-scaled.jpg',
];
---
<Layout title="Internal & External Painting">
  <Header />
  <div style="padding-top:64px;">
    <ServiceHero title="Internal & External Painting" description="Premium painting services using high-quality materials and professional application techniques for interiors and exteriors." heroImage="/images/IMG_20240722_172415-1.jpg" />
    <ServiceGallery images={images} />
    <CTABanner heading="READY? Let's Build A Plan Together" />
  </div>
  <Footer />
</Layout>
