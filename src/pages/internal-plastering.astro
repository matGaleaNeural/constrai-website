---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceHero from '../components/ServiceHero.astro';
import ServiceGallery from '../components/ServiceGallery.astro';
import CTABanner from '../components/CTABanner.astro';
const images = [
  '/images/IMG_20240509_143603-1-300x169.jpg',
  '/images/IMG_20240722_063716-1024x683.jpg',
  '/images/IMG_20240722_190220-scaled.jpg',
];
---
<Layout title="Internal Plastering">
  <Header />
  <div style="padding-top:64px;">
    <ServiceHero title="Internal Plastering" description="High-end interior plastering using gypsum and sand-cement systems — delivering smooth, durable surfaces ready for painting or tiling." heroImage="/images/IMG_20240509_143603-1-300x169.jpg" heroBg="/images/IMG_20240722_063716-1024x683.jpg" />
    <ServiceGallery images={images} />
    <CTABanner heading="READY? Let's Build A Plan Together" />
  </div>
  <Footer />
</Layout>
