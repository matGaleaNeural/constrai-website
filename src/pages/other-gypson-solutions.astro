---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceHero from '../components/ServiceHero.astro';
import ServiceGallery from '../components/ServiceGallery.astro';
import CTABanner from '../components/CTABanner.astro';
const images = [
  '/images/IMG-20260126-WA0124-2-1024x461.jpg',
  '/images/IMG_20240722_190220-scaled.jpg',
];
---
<Layout title="Other Gypsum Solutions">
  <Header />
  <div style="padding-top:64px;">
    <ServiceHero title="Other Gypsum Solutions" description="Tailored gypsum solutions for ceilings, bulkheads, decorative features, and specialist interior finishing requirements." heroImage="/images/IMG-20260126-WA0124-2-1024x461.jpg" />
    <ServiceGallery images={images} />
    <CTABanner heading="READY? Let's Build A Plan Together" />
  </div>
  <Footer />
</Layout>
