---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceHero from '../components/ServiceHero.astro';
import ServiceGallery from '../components/ServiceGallery.astro';
import CTABanner from '../components/CTABanner.astro';
const images = [
  '/images/IMG-20260303-WA0072-1.jpg',
  '/images/IMG_20240722_190220-scaled.jpg',
];
---
<Layout title="Planters">
  <Header />
  <div style="padding-top:64px;">
    <ServiceHero title="Planters" description="Specialized waterproofing and protective lining for planters, ensuring water containment without compromising structure or aesthetics." heroImage="/images/IMG-20260303-WA0072-1.jpg" />
    <ServiceGallery images={images} />
    <CTABanner heading="READY? Let's Build A Plan Together" />
  </div>
  <Footer />
</Layout>
