---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceHero from '../components/ServiceHero.astro';
import ServiceGallery from '../components/ServiceGallery.astro';
import CTABanner from '../components/CTABanner.astro';
const images = [
  '/images/IMG_20200831_155045-1-1.jpg',
  '/images/IMG_20240722_190220-scaled.jpg',
];
---
<Layout title="Walls">
  <Header />
  <div style="padding-top:64px;">
    <ServiceHero title="Walls" description="Premium installation of ceramic, porcelain, and natural stone wall tiles for interiors and wet rooms." heroImage="/images/IMG_20200831_155045-1-1.jpg" />
    <ServiceGallery images={images} />
    <CTABanner heading="READY? Let's Build A Plan Together" />
  </div>
  <Footer />
</Layout>
